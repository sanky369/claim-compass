MONGODB_URI=
MONGODB_DATABASE=claimcompass

# Optional local final-testing switch. When set to "yes", smoke scripts read
# mongodb-uri from Google Secret Manager instead of local MONGODB_URI.
CLAIMCOMPASS_USE_SECRET_MANAGER=no

# Optional. Keep false for the hackathon smoke test because the demo must prove
# write-back through MongoDB MCP.
MDB_MCP_READ_ONLY=false
